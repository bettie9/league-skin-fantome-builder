        -image "lemon3d/texture.png" 
        -image1 "lemon3d/texture.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\nfrom maya.OpenMaya import MGlobal\nimport os.path\nfrom LtMAO import lepath, pyRitoFile, Ritoddstex, hash_helper\n\ndef set_render_settings():\n    # render with depth peeling\n    cmds.setAttr('hardwareRenderingGlobals.transparencyAlgorithm', 3)\n\n    # set smooth shade + texture on\n    for view_panes in cmds.getPanel(type='modelPanel'):\n        if cmds.modelEditor(view_panes, query=True, activeView=True):\n            cmds.modelEditor(view_panes, edit=True, displayAppearance='smoothShaded')\n            cmds.modelEditor(view_panes, edit=True, displayTextures=True)\n            break\n\n\ndef create_ui_materials_import():\n    ui_values = {\n        'materials_bin': '',\n        'wad_folder': ''\n    }\n\n    def ui_cmd():\n        cmds.columnLayout()\n\n        cmds.rowLayout(numberOfColumns=3, adjustableColumn=3)\n        cmds.text(label='Skin BIN:')\n        materials_bin_text = cmds.text(label='', align='left', width=600)\n        def materialsbin_browse(e):\n            materials_bin = cmds.fileDialog2(\n                dialogStyle=2, \n                fileMode=1,\n                fileFilter='BIN(*.bin)',\n                caption='Select Skin BIN',\n                okCaption='Select'\n            )\n            if materials_bin:\n                materials_bin = materials_bin[0].replace('\\\\', '/')\n                cmds.text(materials_bin_text, edit=True, label=materials_bin)\n                ui_values['materials_bin'] = materials_bin\n        cmds.button(label='Browse Skin BIN', command=materialsbin_browse)\n        cmds.setParent('..')\n\n        cmds.rowLayout(numberOfColumns=3, adjustableColumn=3)\n        cmds.text(label='WAD Folder:')\n        wad_folder_text = cmds.text(label='', align='left', width=600)\n        def wadfolder_browse(e):\n            wad_folder = cmds.fileDialog2(\n                dialogStyle=2, \n                fileMode=3,\n                caption='Select WAD Folder',\n                okCaption='Select'\n            )\n            if wad_folder:\n                wad_folder = wad_folder[0].replace('\\\\', '/')\n                cmds.text(wad_folder_text, edit=True, label=wad_folder)\n                ui_values['wad_folder'] = wad_folder\n        cmds.button(label='Browse WAD Folder', command=wadfolder_browse)\n        cmds.setParent('..')\n\n        cmds.rowLayout(numberOfColumns=2)\n        cmds.text(label='', w=700)\n        def dismiss(result):\n            cmds.layoutDialog(dismiss=result)\n        cmds.button(label='Import', width=100, command=lambda e: dismiss('Import'))\n    \n    return cmds.layoutDialog(title='Import Materials', ui=ui_cmd), ui_values\n\ndef parse_read_materials(bin):\n    materials = {}\n    # first run to get main_texture and material link\n    for entry in bin.entries:\n        if entry.type == hash_helper.Storage.bin_hashes['SkinCharacterDataProperties']:\n            skinMeshPropertiess = entry.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['skinMeshProperties'])  \n            if len(skinMeshPropertiess) > 0:\n                skinMeshProperties = skinMeshPropertiess[0]\n                textures = skinMeshProperties.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['texture'])    \n                if len(textures) > 0:\n                    materials['main_texture'] = textures[0].data\n\n                materialOverrides = skinMeshProperties.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['materialOverride'])    \n                if len(materialOverrides) > 0:\n                    materialOverride = materialOverrides[0]\n                    for SkinMeshDataProperties_MaterialOverride in materialOverride.data:\n                        material = SkinMeshDataProperties_MaterialOverride.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['material'])            \n                        submesh = SkinMeshDataProperties_MaterialOverride.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['submesh'])\n                        if len(material) > 0 and len(submesh) > 0:\n                            materials[submesh[0].data] = material[0].data\n            break\n    # second run to get material texture from material link\n    for material, texture in materials.items():\n        if material != 'main_texture': \n            StaticMaterialDefs = bin.get_items(\n                lambda entry: entry.hash == texture and entry.type == hash_helper.Storage.bin_hashes['StaticMaterialDef']\n            )   \n            if len(StaticMaterialDefs) > 0:\n                StaticMaterialDef = StaticMaterialDefs[0]\n                samplerValuess = StaticMaterialDef.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['samplerValues'])\n                if len(samplerValuess) > 0:\n                    samplerValues = samplerValuess[0]\n                    for StaticMaterialShaderSamplerDef in samplerValues.data:\n                        textureNames = StaticMaterialShaderSamplerDef.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['textureName'])            \n                        texturePaths = StaticMaterialShaderSamplerDef.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['texturePath'])\n                        if len(textureNames) > 0 and len(texturePaths) > 0:\n                            if textureNames[0].data in ('DiffuseTexture', 'Diffuse_Texture'):\n                                materials[material] = texturePaths[0].data\n    return materials\n\ndef update_read_materials(materials, wad_folder):\n    materials2 = {}\n    for material, texture in materials.items():\n        texture = lepath.join(wad_folder, texture)\n        # tex to dds \n        if texture.endswith('.tex') and os.path.exists(texture):\n            dds = texture.replace('.tex', '.dds')\n            Ritoddstex.tex2dds(texture, dds)\n            texture = dds\n        material = material.replace('/', '__')\n        materials2[material] = texture\n    return materials2\n\ndef load_materials(materials):\n    # load main texture first\n    scene_materials = []\n    meshes=cmds.ls(sl=True, dag=True, s=True)\n    if meshes != None and len(meshes)>0:\n        scope=cmds.listConnections(meshes, type ='shadingEngine')\n        if scope != None:\n            for shading_engine in scope:\n                if cmds.sets(shading_engine, q=True):\n                    for material in cmds.ls(cmds.listConnections(shading_engine), materials=True):\n                        if material not in scene_materials:\n                            scene_materials.append(material)\n    if len(scene_materials) == 0:\n        raise Exception('Please select a skin group.')\n    main_texture = 'main_texture'\n    # create file + p2d node\n    cmds.shadingNode(\n        'file',\n        name=f'{main_texture}_file',\n        asTexture=True,\n        isColorManaged=True\n    )\n    cmds.shadingNode(\n        'place2dTexture',\n        asUtility=True,\n        name=f'{main_texture}_p2d'\n    )\n    # link stuffs\n    cmds.setAttr(\n        f'{main_texture}_file.fileTextureName',\n        materials['main_texture'],\n        type='string'\n    )\n    attributes = [\n        'coverage',\n        'translateFrame',\n        'rotateFrame',\n        'mirrorU',\n        'mirrorV',\n        'stagger',\n        'wrapU',\n        'wrapV',\n        'repeatUV',\n        'offset',\n        'rotateUV',\n        'noiseUV',\n        'vertexUvOne',\n        'vertexUvTwo',\n        'vertexUvThree',\n        'vertexCameraOne'\n    ]\n    for attribute in attributes:\n        cmds.connectAttr(\n            f'{main_texture}_p2d.{attribute}',\n            f'{main_texture}_file.{attribute}',\n            force=True\n        )\n    cmds.connectAttr(\n        f'{main_texture}_p2d.outUV',\n        f'{main_texture}_file.uv',\n        force=True\n    )\n    cmds.connectAttr(\n        f'{main_texture}_p2d.outUvFilterSize',\n        f'{main_texture}_file.uvFilterSize',\n        force=True\n    )\n    # connect texture depend on material type\n    for scene_material in scene_materials:\n        if cmds.nodeType(scene_material) == 'standardSurface':\n            # set specular to 0\n            cmds.setAttr(f'{scene_material}.specular', 0)\n            cmds.connectAttr(\n                f'{main_texture}_file.outColor',\n                f'{scene_material}.baseColor',\n                force=True\n            )\n        else:\n            cmds.connectAttr(\n                f'{main_texture}_file.outColor',\n                f'{scene_material}.color',\n                force=True\n            )\n    # load other material\n    for material, texture in materials.items():\n        if material not in scene_materials:\n            continue\n        # create file + p2d node\n        cmds.shadingNode(\n            'file',\n            name=f'{material}_file',\n            asTexture=True,\n            isColorManaged=True\n        )\n        cmds.shadingNode(\n            'place2dTexture',\n            asUtility=True,\n            name=f'{material}_p2d'\n        )\n        # link stuffs\n        cmds.setAttr(\n            f'{material}_file.fileTextureName',\n            texture,\n            type='string'\n        )\n        attributes = [\n            'coverage',\n            'translateFrame',\n            'rotateFrame',\n            'mirrorU',\n            'mirrorV',\n            'stagger',\n            'wrapU',\n            'wrapV',\n            'repeatUV',\n            'offset',\n            'rotateUV',\n            'noiseUV',\n            'vertexUvOne',\n            'vertexUvTwo',\n            'vertexUvThree',\n            'vertexCameraOne'\n        ]\n        for attribute in attributes:\n            cmds.connectAttr(\n                f'{material}_p2d.{attribute}',\n                f'{material}_file.{attribute}',\n                force=True\n            )\n        cmds.connectAttr(\n            f'{material}_p2d.outUV',\n            f'{material}_file.uv',\n            force=True\n        )\n        cmds.connectAttr(\n            f'{material}_p2d.outUvFilterSize',\n            f'{material}_file.uvFilterSize',\n            force=True\n        )\n        # connect texture depend on material type\n        if cmds.nodeType(material) == 'standardSurface':\n            # set specular to 0\n            cmds.setAttr(f'{material}.specular', 0)\n            cmds.connectAttr(\n                f'{material}_file.outColor',\n                f'{material}.baseColor',\n                force=True\n            )\n        else:\n            cmds.connectAttr(\n                f'{material}_file.outColor',\n                f'{material}.color',\n                force=True\n            )\n                \ndef read_and_load():\n    dismiss, ui_values = create_ui_materials_import()\n    if dismiss == 'Import':\n        wad_folder = ui_values['wad_folder']\n        materials_bin = ui_values['materials_bin']\n        if wad_folder == '' or materials_bin == '':\n            return\n        # pase the bin\n        materials = parse_read_materials(pyRitoFile.bin.BIN().read(materials_bin))\n        # update material, texture to match maya/wad folder\n        materials = update_read_materials(materials, wad_folder)\n        # load materials in maya\n        load_materials(materials)\n        # set render\n        set_render_settings()\n        MGlobal.displayInfo(f'Finish: Load materials.')\n        \nread_and_load()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
