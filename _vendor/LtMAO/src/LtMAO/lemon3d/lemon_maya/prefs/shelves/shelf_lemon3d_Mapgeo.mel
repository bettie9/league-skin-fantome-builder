        -command "from maya import cmds\n\ndef create_ui_mapgeo_model_info(transform_name, mesh_name, mesh_materials, layers, is_bush, render_flags, bucket_grid_hash):\n    def ui_cmd():\n        cmds.columnLayout()\n        cmds.rowColumnLayout(numberOfColumns = 2, width = 800)\n\n        cmds.text(label = 'Mesh name:', width = 150, height = 30)\n        cmds.text(label = mesh_name, width = 650, height = 30)\n\n        cmds.text(label = 'Materials:', width = 150, height = 30)\n        cmds.columnLayout(height = 30)\n        for material in mesh_materials:\n            cmds.text(material, width = 650)\n        cmds.setParent('..')\n        cmds.text(label = 'Layer:', width = 150, height = 30)\n        cmds.rowLayout(numberOfColumns = 8, height = 30)\n        layers_checkbox = [None] * 8\n        for i in range(8):\n            layers_checkbox[i] = cmds.checkBox(label = f'{i+1}', value = layers[i])\n        cmds.setParent('..')\n\n        cmds.text(label = 'Is bush:', width = 150, height = 30)\n        bush_checkbox = cmds.checkBox(label = 'Yes', height = 30, value = is_bush)\n\n        cmds.text(label = 'Render flags:', width = 150, height = 30)\n        render_flags_intfield = cmds.intField(minValue = 0, maxValue = 255, step = 1, value = render_flags)\n\n        cmds.text(label = 'Bucket grid hash:', width = 150, height = 30)\n        cmds.rowLayout(numberOfColumns = 2, height = 30)\n        option_items  =  {\n            'f4968631': 'Enable on Baron Base',\n            'c11c84e8': 'Enable on Baron Walled',\n            '1b3399aa': 'Enable on Baron Tunnel',\n            '68fe7644': 'Enable on Baron Upgraded',\n            'd1a17399': 'Enable on Dragon Infernal',\n            '9f32344a': 'Enable on Dragon Infernal',\n            'e94a0c8c': 'Enable on Dragon Mountain',\n            '48106271': 'Enable on Dragon Mountain',\n            '84543212': 'Enable on Dragon Ocean',\n            '3c5b24f7': 'Enable on Dragon Ocean',\n            '8c67e893': 'Enable on Dragon Cloud',\n            '4f0b2a3e': 'Enable on Dragon Cloud',\n            '86fb6b5b': 'Enable on Dragon Hextech',\n            '2b8dbdee': 'Enable on Dragon Hextech',\n            '8e6a128e': 'Enable on Dragon Chemtech',\n            '189a3295': 'Enable on Dragon Chemtech',\n            '7acdec29': 'Enable on Athakhan Top',\n            'd5adc7f7': 'Enable on Athakhan Bottom',\n\n            '00000000': 'Base Default',\n            '21d36b37': 'Disable on Baron Tunnel',\n            '3ea0f6af': 'Disable on Dragon Mountain, Hextech, Chemtech',\n            '5e652742': 'Disable on Dragon Infernal, Mountain, Ocean, Cloud, Hextech, Chemtech',\n            '6f187e01': 'Disable on Dragon Infernal, Hextech, Chemtech',\n            '72a6d263': 'Disable on Dragon Ocean',\n            '789a0ddf': 'Disable on Dragon Infernal, Hextech, Chemtech',\n            '7af438ae': 'Disable on Dragon Infernal',\n            '8b933f10': 'Disable on Dragon Infernal',\n            'a7b30f31': 'Disable on Baron Base, Baron Upgraded',\n            '0c210e40': 'Disable on Dragon Mountain',\n            '98689027': 'Disable on Dragon Mountain, Infernal',\n        }\n        buckethash_field = cmds.textField(width = 400, text = bucket_grid_hash)\n        option_menu = cmds.optionMenu(width = 250)\n        for item, desc in option_items.items():\n            cmds.menuItem(label = f'{item} ({desc})')\n        if bucket_grid_hash in option_items:\n            value_to_set = f'{bucket_grid_hash} ({option_items[bucket_grid_hash]})'\n        else:\n            value_to_set = f'00000000 (Base Default)'\n        def option_menu_change(v):\n            cmds.textField(buckethash_field, edit = True, text = v.split(' ')[0])\n        cmds.optionMenu(option_menu, edit = True, value = value_to_set, changeCommand=option_menu_change)\n        cmds.setParent('..')\n\n        cmds.setParent('..')\n        def dismiss(result):\n            layers = [False] * 8\n            for i in range(8):\n                layers[i] = cmds.checkBox(layers_checkbox[i], query=True, value=True)\n                if layers[i]: \n                    if not cmds.sets(transform_name, isMember = f'set{i+1}'):\n                        cmds.sets(transform_name, addElement = f'set{i+1}')\n                else:\n                    if cmds.sets(transform_name, isMember = f'set{i+1}'):\n                        cmds.sets(transform_name, remove = f'set{i+1}')\n\n            is_bush = cmds.checkBox(bush_checkbox, query=True, value=True)\n            if is_bush: \n                if not cmds.sets(transform_name, isMember = 'setBushes'):\n                    cmds.sets(transform_name, addElement = 'setBushes')\n            else:\n                if cmds.sets(transform_name, isMember = 'setBushes'):\n                    cmds.sets(transform_name, remove = 'setBushes')\n\n            render_flags = cmds.intField(render_flags_intfield, query=True, value=True)\n            if not cmds.attributeQuery(\n                'renderflags',\n                exists=True,\n                node=transform_name\n            ):\n                cmds.addAttr(\n                    transform_name,\n                    longName='renderflags',\n                    niceName='Render Flags',\n                    attributeType='byte'\n                )\n            cmds.setAttr(f'{transform_name}.renderflags', render_flags)\n\n            bucket_grid_hash = cmds.textField(buckethash_field, query=True, text=True)\n            if not cmds.attributeQuery(\n                'buckethash',\n                exists=True,\n                node=transform_name\n            ):\n                cmds.addAttr(\n                    transform_name,\n                    longName='buckethash',\n                    niceName='Bucket Hash',\n                    dataType='string'\n                )\n            cmds.setAttr(f'{transform_name}.buckethash', bucket_grid_hash, type='string')\n\n\n            cmds.layoutDialog(dismiss = result)\n        cmds.rowLayout(numberOfColumns = 2)\n        cmds.text(label = '', w = 700)\n        cmds.button(label = 'Apply', width = 100, height = 30, align = 'right', command = lambda e: dismiss('Apply'))\n        cmds.setParent('..')\n    \n    return cmds.layoutDialog(title = 'Mapgeo mesh info', ui = ui_cmd)\n\n\nmeshes = cmds.ls(selection = True, dagObjects = True, shapes = True)\nif meshes:\n    mesh_name = meshes[0]\n    transform_name = cmds.listRelatives(mesh_name, parent=True)[0]\n    scope = cmds.listConnections(mesh_name, type = 'shadingEngine')\n    mesh_materials = []\n    if scope:\n        for shading_engine in scope:\n            if cmds.sets(shading_engine, query = True):\n                mesh_materials += cmds.ls(cmds.listConnections(shading_engine), materials = True)\n        mesh_materials = list(set(mesh_materials))   \n    \n    layers = [False] * 8\n    for i in range(8):\n        layers[i] = cmds.sets(transform_name, isMember = f'set{i+1}')\n    is_bush = cmds.sets(transform_name, isMember = 'setBushes')\n\n    render_flags = 0\n    try:\n        if cmds.attributeQuery(\n            'renderflags',\n            exists=True,\n            node=transform_name\n        ):\n            render_flags = cmds.getAttr(f'{transform_name}.renderflags')\n    except:\n        pass\n\n    bucket_grid_hash = '00000000'\n    try:\n        if cmds.attributeQuery(\n            'buckethash',\n            exists=True,\n            node=transform_name\n        ):\n            bucket_grid_hash = cmds.getAttr(f'{transform_name}.buckethash')\n    except:\n        pass\n    create_ui_mapgeo_model_info(transform_name, mesh_name, mesh_materials, layers, is_bush, render_flags, bucket_grid_hash)" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
