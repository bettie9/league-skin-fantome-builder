        -image "lemon3d/texture.png" 
        -image1 "lemon3d/texture.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\nfrom maya.OpenMaya import MGlobal\nimport os.path\nfrom LtMAO import lepath, pyRitoFile, Ritoddstex, hash_helper\n\ndef set_render_settings():\n    # render with depth peeling\n    cmds.setAttr('hardwareRenderingGlobals.transparencyAlgorithm', 3)\n\n    # set smooth shade + texture on\n    for view_panes in cmds.getPanel(type='modelPanel'):\n        if cmds.modelEditor(view_panes, query=True, activeView=True):\n            cmds.modelEditor(view_panes, edit=True, displayAppearance='smoothShaded')\n            cmds.modelEditor(view_panes, edit=True, displayTextures=True)\n            break\n\n\ndef create_ui_materials_import():\n    ui_values = {\n        'materials_bin': '',\n        'wad_folder': ''\n    }\n\n    def ui_cmd():\n        cmds.columnLayout()\n\n        cmds.rowLayout(numberOfColumns=3, adjustableColumn=3)\n        cmds.text(label='Materials BIN:')\n        materials_bin_text = cmds.text(label='', align='left', width=600)\n        def materialsbin_browse(e):\n            materials_bin = cmds.fileDialog2(\n                dialogStyle=2, \n                fileMode=1,\n                fileFilter='BIN(*.bin)',\n                caption='Select Materials BIN',\n                okCaption='Select'\n            )\n            if materials_bin:\n                materials_bin = materials_bin[0].replace('\\\\', '/')\n                cmds.text(materials_bin_text, edit=True, label=materials_bin)\n                ui_values['materials_bin'] = materials_bin\n        cmds.button(label='Browse Materials BIN', command=materialsbin_browse)\n        cmds.setParent('..')\n\n        cmds.rowLayout(numberOfColumns=3, adjustableColumn=3)\n        cmds.text(label='WAD Folder:')\n        wad_folder_text = cmds.text(label='', align='left', width=600)\n        def wadfolder_browse(e):\n            wad_folder = cmds.fileDialog2(\n                dialogStyle=2, \n                fileMode=3,\n                caption='Select WAD Folder',\n                okCaption='Select'\n            )\n            if wad_folder:\n                wad_folder = wad_folder[0].replace('\\\\', '/')\n                cmds.text(wad_folder_text, edit=True, label=wad_folder)\n                ui_values['wad_folder'] = wad_folder\n        cmds.button(label='Browse WAD Folder', command=wadfolder_browse)\n        cmds.setParent('..')\n\n        cmds.rowLayout(numberOfColumns=2)\n        cmds.text(label='', w=700)\n        def dismiss(result):\n            cmds.layoutDialog(dismiss=result)\n        cmds.button(label='Import', width=100, command=lambda e: dismiss('Import'))\n    \n    return cmds.layoutDialog(title='Import Materials', ui=ui_cmd), ui_values\n\ndef parse_read_materials(bin):\n    materials = {}\n    for entries in bin.entries:\n        if entries.type == hash_helper.Storage.bin_hashes['StaticMaterialDef']:\n            names = entries.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['name'])            \n            samplerValuess = entries.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['samplerValues'])\n            if len(names) > 0 and len(samplerValuess) > 0:\n                for StaticMaterialShaderSamplerDef in samplerValuess[0].data:\n                    textureNames = StaticMaterialShaderSamplerDef.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['textureName'])            \n                    texturePaths = StaticMaterialShaderSamplerDef.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['texturePath'])\n                    if len(textureNames) > 0 and len(texturePaths) > 0:\n                        if textureNames[0].data in ('DiffuseTexture', 'Diffuse_Texture'):\n                            materials[names[0].data] = texturePaths[0].data\n    return materials\n\ndef update_read_materials(materials, wad_folder):\n    materials2 = {}\n    for material, texture in materials.items():\n        texture = lepath.join(wad_folder, texture)\n        # tex to dds \n        if texture.endswith('.tex') and os.path.exists(texture):\n            dds = texture.replace('.tex', '.dds')\n            Ritoddstex.tex2dds(texture, dds)\n            texture = dds\n        material = material.replace('/', '__')\n        materials2[material] = texture\n    return materials2\n\ndef load_materials(materials):\n    for material, texture in materials.items():\n        if not cmds.objExists(material):\n            continue\n        # create file + p2d node\n        cmds.shadingNode(\n            'file',\n            name=f'{material}_file',\n            asTexture=True,\n            isColorManaged=True\n        )\n        cmds.shadingNode(\n            'place2dTexture',\n            asUtility=True,\n            name=f'{material}_p2d'\n        )\n        # link stuffs\n        cmds.setAttr(\n            f'{material}_file.fileTextureName',\n            texture,\n            type='string'\n        )\n        attributes = [\n            'coverage',\n            'translateFrame',\n            'rotateFrame',\n            'mirrorU',\n            'mirrorV',\n            'stagger',\n            'wrapU',\n            'wrapV',\n            'repeatUV',\n            'offset',\n            'rotateUV',\n            'noiseUV',\n            'vertexUvOne',\n            'vertexUvTwo',\n            'vertexUvThree',\n            'vertexCameraOne'\n        ]\n        for attribute in attributes:\n            cmds.connectAttr(\n                f'{material}_p2d.{attribute}',\n                f'{material}_file.{attribute}',\n                force=True\n            )\n        cmds.connectAttr(\n            f'{material}_p2d.outUV',\n            f'{material}_file.uv',\n            force=True\n        )\n        cmds.connectAttr(\n            f'{material}_p2d.outUvFilterSize',\n            f'{material}_file.uvFilterSize',\n            force=True\n        )\n        # connect texture depend on material type\n        if cmds.nodeType(material) == 'standardSurface':\n            # set specular to 0\n            cmds.setAttr(f'{material}.specular', 0)\n            cmds.connectAttr(\n                f'{material}_file.outColor',\n                f'{material}.baseColor',\n                force=True\n            )\n        else:\n            cmds.connectAttr(\n                f'{material}_file.outColor',\n                f'{material}.color',\n                force=True\n            )\n                \ndef read_and_load():\n    dismiss, ui_values = create_ui_materials_import()\n    if dismiss == 'Import':\n        wad_folder = ui_values['wad_folder']\n        materials_bin = ui_values['materials_bin']\n        if wad_folder == '' or materials_bin == '':\n            return\n        # pase the bin\n        materials = parse_read_materials(pyRitoFile.bin.BIN().read(materials_bin))\n        # update material, texture to match maya/wad folder\n        materials = update_read_materials(materials, wad_folder)\n        # load materials in maya\n        load_materials(materials)\n        # set render\n        set_render_settings()\n        MGlobal.displayInfo(f'Finish: Load {len(materials)} materials.')\n        \nread_and_load()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Export and append all materials to materials.bin." 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Export materials" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "EXP" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 1 
        -image "lemon3d/texture.png" 
        -image1 "lemon3d/texture.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\nfrom maya.OpenMaya import MGlobal\nimport os.path\nfrom LtMAO import pyRitoFile, Ritoddstex, hash_helper\n\ndef create_ui_material_export():\n    ui_values = {\n        'materials_bin': '',\n        'map_name': ''\n    }\n\n    def ui_cmd():\n        cmds.columnLayout()\n\n        cmds.rowLayout(numberOfColumns=3, adjustableColumn=3)\n        cmds.text(label='Texture path: ASSETS/Maps/KitPieces/')\n        map_name = cmds.textField(width=500)\n        cmds.text(label='/Textures/*.dds')\n        cmds.setParent('..')\n\n        cmds.rowLayout(numberOfColumns=3, adjustableColumn=3)\n        cmds.text(label='Materials BIN:')\n        materials_bin_text = cmds.text(label='', align='left', width=600)\n        def materialsbin_browse(e):\n            materials_bin = cmds.fileDialog2(\n                dialogStyle=2, \n                fileMode=1,\n                fileFilter='BIN(*.bin)',\n                caption='Select Materials BIN',\n                okCaption='Select'\n            )\n            if materials_bin:\n                materials_bin = materials_bin[0].replace('\\\\', '/')\n                cmds.text(materials_bin_text, edit=True, label=materials_bin)\n                ui_values['materials_bin'] = materials_bin\n        cmds.button(label='Browse Materials BIN', command=materialsbin_browse)\n        cmds.setParent('..')\n\n        cmds.rowLayout(numberOfColumns=2)\n        cmds.text(label='', w=700)\n        def dismiss(result):\n            ui_values['map_name'] = cmds.textField(map_name, query=True, text=True)\n            cmds.layoutDialog(dismiss=result)\n        cmds.button(label='Export', width=100, command=lambda e: dismiss('Export'))\n    \n    return cmds.layoutDialog(title='Export Materials', ui=ui_cmd), ui_values\n\ndef parse_write_materials(materials, bin):\n    entries = []\n    for entry in bin.entries:\n        duped = False\n        for material, texture in materials.items():\n            if hash_helper.Storage.bin_hashes[material] == entry.hash:\n                duped = True\n                break\n        if not duped:\n            entries.append(entry)\n    for material, texture in materials.items():\n        StaticMaterialDef = pyRitoFile.bin.BINEntry(\n            hash = material, type = 'StaticMaterialDef',\n            data = [\n                pyRitoFile.bin.BINField(\n                    hash = 'name',\n                    type = pyRitoFile.bin.BINType.STRING,\n                    data = material\n                ),\n                pyRitoFile.bin.BINField(\n                    hash = 'type',\n                    type = pyRitoFile.bin.BINType.U32,\n                    data = 0\n                ),\n                pyRitoFile.bin.BINField(\n                    hash = 'defaultTechnique',\n                    type = pyRitoFile.bin.BINType.STRING,\n                    data = 'normal'\n                ),\n                pyRitoFile.bin.BINField(\n                    hash = 'samplerValues',\n                    type = pyRitoFile.bin.BINType.LIST2,\n                    value_type = pyRitoFile.bin.BINType.EMBED,\n                    data = [\n                        pyRitoFile.bin.BINField(\n                            hash = None,\n                            type = pyRitoFile.bin.BINType.EMBED,\n                            hash_type = 'StaticMaterialShaderSamplerDef',\n                            data = [\n                                pyRitoFile.bin.BINField(\n                                    hash = 'samplerName',\n                                    type = pyRitoFile.bin.BINType.STRING, \n                                    data = 'DiffuseTexture'\n                                ),\n                                pyRitoFile.bin.BINField(\n                                    hash = 'textureName',\n                                    type = pyRitoFile.bin.BINType.STRING,\n                                    data = texture\n                                ),\n                                pyRitoFile.bin.BINField(\n                                    hash = 'addressU',\n                                    type = pyRitoFile.bin.BINType.U32,\n                                    data = 1\n                                )\n                            ]\n                        )\n                    ]\n                ),\n                pyRitoFile.bin.BINField(\n                    hash = 'switches',\n                    type =  pyRitoFile.bin.BINType.LIST2,\n                    value_type = pyRitoFile.bin.BINType.EMBED,\n                    data = [\n                        pyRitoFile.bin.BINField(\n                            hash = None,\n                            type =  pyRitoFile.bin.BINType.EMBED,\n                            hash_type = 'StaticMaterialSwitchDef',\n                            data = [\n                                pyRitoFile.bin.BINField(\n                                    hash = 'name',\n                                    type =  pyRitoFile.bin.BINType.STRING,\n                                    data = 'MASK_FX_IN_MAP_CENTER'\n                                ),\n                                pyRitoFile.bin.BINField(\n                                    hash = 'on',\n                                    type =  pyRitoFile.bin.BINType.BOOL,\n                                    data = False\n                                )\n                            ]\n                        )\n                    ]\n                ),\n                pyRitoFile.bin.BINField(\n                    hash = 'shaderMacros',\n                    type =  pyRitoFile.bin.BINType.MAP,\n                    key_type = pyRitoFile.bin.BINType.STRING,\n                    value_type = pyRitoFile.bin.BINType.STRING,\n                    data = {\n                        'NO_BAKED_LIGHTING': '1',\n                        'DISABLE_DEPTH_FOG': '1',\n                        'PREMULTIPLIED_ALPHA': '1'\n                    }\n                ),\n                pyRitoFile.bin.BINField(\n                    hash = 'techniques',\n                    type =  pyRitoFile.bin.BINType.LIST,\n                    value_type = pyRitoFile.bin.BINType.EMBED,\n                    data = [\n                        pyRitoFile.bin.BINField(\n                            hash = None,\n                            type =  pyRitoFile.bin.BINType.EMBED,\n                            hash_type = 'StaticMaterialTechniqueDef',\n                            data = [\n                                pyRitoFile.bin.BINField(\n                                    hash = 'name',\n                                    type =  pyRitoFile.bin.BINType.STRING,\n                                    data = 'normal'\n                                ),\n                                pyRitoFile.bin.BINField(\n                                    hash = 'passes',\n                                    type =  pyRitoFile.bin.BINType.LIST,\n                                    value_type = pyRitoFile.bin.BINType.EMBED,\n                                    data = [\n                                        pyRitoFile.bin.BINField(\n                                            hash = None,\n                                            type =  pyRitoFile.bin.BINType.EMBED,\n                                            hash_type = 'StaticMaterialPassDef',\n                                            data = [\n                                                pyRitoFile.bin.BINField(\n                                                    hash = 'shader',\n                                                    type =  pyRitoFile.bin.BINType.LINK,\n                                                    data = 'Shaders/StaticMesh/SRX_Blend_Master'\n                                                ),\n                                                pyRitoFile.bin.BINField(\n                                                    hash = 'cullEnable',\n                                                    type =  pyRitoFile.bin.BINType.BOOL,\n                                                    data = False\n                                                )\n                                            ]\n                                        )\n                                    ]\n                                )\n                            ]\n                        )\n                    ]\n                ),\n                pyRitoFile.bin.BINField(\n                    hash = 'childTechniques',\n                    type =  pyRitoFile.bin.BINType.LIST,\n                    value_type = pyRitoFile.bin.BINType.EMBED,\n                    data = [\n                        pyRitoFile.bin.BINField(\n                            hash = None,\n                            type =  pyRitoFile.bin.BINType.EMBED,\n                            hash_type = 'StaticMaterialChildTechniqueDef',\n                            data = [\n                                pyRitoFile.bin.BINField(\n                                    hash = 'name',\n                                    type =  pyRitoFile.bin.BINType.STRING,\n                                    data = 'env_transition'\n                                ),\n                                pyRitoFile.bin.BINField(\n                                    hash = 'parentName',\n                                    type =  pyRitoFile.bin.BINType.STRING,\n                                    data = 'normal'\n                                ),\n                                pyRitoFile.bin.BINField(\n                                    hash = 'shaderMacros',\n                                    type =  pyRitoFile.bin.BINType.MAP,\n                                    key_type = pyRitoFile.bin.BINType.STRING,\n                                    value_type = pyRitoFile.bin.BINType.STRING,\n                                    data = {\n                                        'ENV_TRANSITION': '1'\n                                    }\n                                )\n                            ]\n                        )\n                    ]\n                )\n            ]\n        )\n        entries.append(StaticMaterialDef)\n    bin.entries = entries\n\ndef update_write_materials(materials, map_name):\n    materials2 = {}\n    for material, texture in materials.items():\n        material = material.replace('__', '/')\n        texture = f'ASSETS/Maps/KitPieces/{map_name}/Textures/{os.path.basename(texture)}'\n        materials2[material] = texture\n    return materials2\n\ndef dump_materials():\n    materials = {}\n    meshes=cmds.ls(sl=True, dag=True, s=True)\n    if meshes != None and len(meshes)>0:\n        scope=cmds.listConnections(meshes, type ='shadingEngine')\n    else:\n        scope=cmds.ls(type='shadingEngine')\n    if scope != None:\n        list_materials_in_scene = []\n        for shading_engine in scope:\n            if cmds.sets(shading_engine, q=True):\n                list_materials_in_scene += cmds.ls(cmds.listConnections(shading_engine), materials=True)\n        for material in list_materials_in_scene:\n            if material in materials:\n                continue\n            # list file depend on material type\n            if cmds.nodeType(material) == 'standardSurface':\n                material_file = cmds.listConnections(f'{material}.baseColor', type='file')\n            else:\n                material_file = cmds.listConnections(f'{material}.color', type='file')\n            if material_file:\n                texture = cmds.getAttr(f'{material_file[0]}.fileTextureName')\n                materials[material] = texture\n    return materials\n\ndef dump_and_write():\n    dismiss, ui_values = create_ui_material_export()\n    if dismiss == 'Export':\n        map_name = ui_values['map_name']\n        materials_bin = ui_values['materials_bin']\n        if map_name == '' or materials_bin == '':\n            return\n        # dump materials in scene\n        materials = dump_materials()\n        # rename material to match bin file + set path of textures\n        materials = update_write_materials(materials, map_name)\n        # read, add materials to the end of entries\n        bin = pyRitoFile.bin.BIN().read(materials_bin)\n        parse_write_materials(materials, bin)\n        bin.write(materials_bin)\n        MGlobal.displayInfo(f'Finish: Dump {len(materials)} materials.')\n        \ndump_and_write()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 3
        -flexibleWidthValue 32
        -enable 1
        -width 35
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Check if scene material is not definied (missing) in materials.bin" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Check missing materials" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "CHK" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 1 
        -image "lemon3d/check_materials.png" 
        -image1 "lemon3d/check_materials.png" 
        -style "iconOnly" 
        -marginWidth 0
        -marginHeight 1
        -command "from maya import cmds\nfrom maya.OpenMaya import MGlobal\nimport os.path\nfrom LtMAO import lepath, pyRitoFile, Ritoddstex, hash_helper\n\ndef parse_read_materials(bin):\n    materials = {}\n    for entries in bin.entries:\n        if entries.type == hash_helper.Storage.bin_hashes['StaticMaterialDef']:\n            names = entries.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['name'])            \n            samplerValuess = entries.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['samplerValues'])\n            if len(names) > 0 and len(samplerValuess) > 0:\n                for StaticMaterialShaderSamplerDef in samplerValuess[0].data:\n                    textureNames = StaticMaterialShaderSamplerDef.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['textureName'])            \n                    texturePaths = StaticMaterialShaderSamplerDef.get_items(lambda field: field.hash == hash_helper.Storage.bin_hashes['texturePath'])\n                    if len(textureNames) > 0 and len(texturePaths) > 0:\n                        if textureNames[0].data in ('DiffuseTexture', 'Diffuse_Texture'):\n                            materials[names[0].data] = texturePaths[0].data\n    return materials\n\ndef update_read_materials(materials, wad_folder):\n    materials2 = {}\n    for material, texture in materials.items():\n        texture = lepath.join(wad_folder, texture)\n        # tex to dds \n        if texture.endswith('.tex') and os.path.exists(texture):\n            dds = texture.replace('.tex', '.dds')\n            Ritoddstex.tex2dds(texture, dds)\n            texture = dds\n        material = material.replace('/', '__')\n        materials2[material] = texture\n    return materials2\n\ndef dump_materials():\n    materials = {}\n    meshes=cmds.ls(sl=True, dag=True, s=True)\n    if meshes != None and len(meshes)>0:\n        scope=cmds.listConnections(meshes, type ='shadingEngine')\n    else:\n        scope=cmds.ls(type='shadingEngine')\n    if scope != None:\n        list_materials_in_scene = []\n        for shading_engine in scope:\n            if cmds.sets(shading_engine, q=True):\n                list_materials_in_scene += cmds.ls(cmds.listConnections(shading_engine), materials=True)\n        for material in list_materials_in_scene:\n            if material in materials:\n                continue\n            materials[material] = ''\n    return materials\n\ndef read_and_check():\n    materials_bin = cmds.fileDialog2(\n        dialogStyle=2, \n        fileMode=1,\n        fileFilter='BIN(*.bin)',\n        caption='Select Materials BIN',\n        okCaption='Check'\n    )\n    if materials_bin:\n        materials_bin = materials_bin[0].replace('\\\\', '/')\n        materials = parse_read_materials(pyRitoFile.bin.BIN().read(materials_bin))\n        materials = update_read_materials(materials, 'whateverthisvar')\n        materials_in_scene = dump_materials()\n\n        missing_materials = []\n        for material in materials_in_scene:\n            if material not in materials:\n                missing_materials.append(material)\n        \n        missing_materials_count = len(missing_materials)\n        if missing_materials_count > 0:\n            missing_materials_str = '\\n'.join(missing_materials)\n            MGlobal.displayInfo(f'Found {missing_materials_count} selected scene materials that are not defined in materials.bin:\\n{missing_materials_str}')\n        else:\n            MGlobal.displayInfo(f'All {len(materials_in_scene)} scene materials are defined in materials.bin')\n\nread_and_check()" 
        -sourceType "python" 
        -commandRepeatable 1
        -flat 1
    ;
