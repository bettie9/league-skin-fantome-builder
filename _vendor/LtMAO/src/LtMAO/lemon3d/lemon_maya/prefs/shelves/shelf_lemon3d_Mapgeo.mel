        -annotation "Read and load textures from materials.bin." 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "Import materials" 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
