        -command "from maya import cmds\n\ntransforms = cmds.ls(transforms = True)\nif transforms:\n    to_selected = []\n    for tranform in transforms:\n        mesh = cmds.listRelatives(tranform, shapes=True)\n        if mesh:\n            try:\n                if cmds.attributeQuery(\n                    'buckethash',\n                    exists=True,\n                    node=tranform\n                ):\n                   bucket_grid_hash = cmds.getAttr(f'{tranform}.buckethash')\n                   if bucket_grid_hash != '00000000':\n                    to_selected.append(tranform)\n            except:\n                pass\n    if len(to_selected) > 0:\n        cmds.select(to_selected)" 
